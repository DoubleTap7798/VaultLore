NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vaultlore
REDIS_URL=redis://localhost:6379
POSTGRES_DB=vaultlore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
EXPO_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
RAILWAY_ENVIRONMENT=local
CORS_ORIGINS=http://localhost:8081,http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PASSWORD_RESET_MAX=5
RATE_LIMIT_UPLOAD_MAX=20

STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=http://localhost:4000
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

EMAIL_PROVIDER=console
EMAIL_API_KEY=
EMAIL_FROM=noreply@vaultlore.app
APP_BASE_URL=http://localhost:8081
REVENUECAT_WEBHOOK_SECRET=

SENTRY_DSN_API=
SENTRY_DSN_WORKER=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

EXPO_PUBLIC_REVENUECAT_KEY=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
