{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@vaultlore/shared": ["packages/shared/src/index.ts"],
      "@vaultlore/api-client": ["packages/api-client/src/index.ts"],
      "@vaultlore/ui": ["packages/ui/src/index.ts"]
    }
  }
}
