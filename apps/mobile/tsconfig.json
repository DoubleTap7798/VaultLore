{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": "../..",
    "paths": {
      "@vaultlore/shared": ["packages/shared/src/index.ts"],
      "@vaultlore/api-client": ["packages/api-client/src/index.ts"],
      "@vaultlore/ui": ["packages/ui/src/index.ts"]
    }
  },
  "include": ["app", "components", "lib", "expo-env.d.ts"]
}
